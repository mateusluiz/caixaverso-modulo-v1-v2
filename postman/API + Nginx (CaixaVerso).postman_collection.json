    {
      "name": "09 - Rate limit (Runner)",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "if (pm.info.iteration === 0) {",
              "    pm.collectionVariables.set('rate_limit_429_count', '0');",
              "}",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status deve ser 200 ou 429', function () {",
              "    pm.expect([200, 429]).to.include(pm.response.code);",
              "});",
              "",
              "if (pm.response.code === 429) {",
              "    const current = Number(pm.collectionVariables.get('rate_limit_429_count') || '0');",
              "    pm.collectionVariables.set('rate_limit_429_count', String(current + 1));",
              "}",
              "",
              "if (pm.info.iterationCount > 1 && pm.info.iteration === pm.info.iterationCount - 1) {",
              "    const total429 = Number(pm.collectionVariables.get('rate_limit_429_count') || '0');",
              "    pm.test('Pelo menos um 429 aconteceu', function () {",
              "        pm.expect(total429).to.be.above(0);",
              "    });",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
