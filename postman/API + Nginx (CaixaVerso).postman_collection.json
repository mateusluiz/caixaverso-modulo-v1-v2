  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "packages": {},
        "requests": {},
        "exec": [
          "const timeZone = \"America/Sao_Paulo\";",
          "",
          "const parts = new Intl.DateTimeFormat(\"en-CA\", {",
          "  timeZone,",
          "  year: \"numeric\",",
          "  month: \"2-digit\",",
          "  day: \"2-digit\"",
          "}).formatToParts(new Date());",
          "",
          "const get = (type) => parts.find(p => p.type === type).value;",
          "",
          "const year = get(\"year\");",
          "const monthNum = get(\"month\");",
          "const day = get(\"day\");",
          "",
          "const month = `${year}-${monthNum}`;",
          "const monthDay = `${year}-${monthNum}-${day}`; ",
          "",
          "pm.collectionVariables.set(\"month\", month);",
          "pm.collectionVariables.set(\"month_day\", monthDay);"
        ]
      }
    },
