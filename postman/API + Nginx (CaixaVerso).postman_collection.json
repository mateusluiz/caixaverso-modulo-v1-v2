    {
      "name": "01 - Reverse proxy (200)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Resposta veio pelo Nginx', function () {",
              "    const server = (pm.response.headers.get('Server') || '').toLowerCase();",
              "    pm.expect(server).to.include('nginx');",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
