    {
      "name": "02 - Security headers",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.response.to.have.status(200);",
              "",
              "pm.test('X-Content-Type-Options = nosniff', function () {",
              "    pm.expect(pm.response.headers.get('X-Content-Type-Options')).to.eql('nosniff');",
              "});",
              "",
              "pm.test('X-Frame-Options = DENY', function () {",
              "    pm.expect(pm.response.headers.get('X-Frame-Options')).to.eql('DENY');",
              "});",
              "",
              "pm.test('X-XSS-Protection contem mode=block', function () {",
              "    const value = pm.response.headers.get('X-XSS-Protection') || '';",
              "    pm.expect(value).to.include('mode=block');",
              "});"
            ]
